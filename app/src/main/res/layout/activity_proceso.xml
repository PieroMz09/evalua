<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".activity_proceso">

    <TextView
        android:id="@+id/tituloProceso"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Guía del proceso de viaje"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#003580"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/>

    <TextView
        android:id="@+id/textoGuia"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="1. Elige tu destino\n2. Selecciona el paquete\n3. Confirma tus datos\n4. Realiza el pago\n5. Recibe tu voucher"
        android:textSize="18sp"
        android:lineSpacingExtra="8dp"
        android:padding="24dp"
        android:background="#F0F0F0"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tituloProceso"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnVolverProceso"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="← VOLVER"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>